# ==========================================================================
# WinSpy — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
#   cp .env.example .env
# ==========================================================================

# --- Base de datos (PostgreSQL) ---------------------------------------------
# Local (docker-compose): el usuario/clave/host coinciden con docker-compose.yml
DATABASE_URL="postgresql://winspy:winspy@localhost:5432/winspy?schema=public"

# --- Redis (cola BullMQ) ----------------------------------------------------
# Local (docker-compose):
REDIS_URL="redis://localhost:6379"

# --- Autenticación ----------------------------------------------------------
# Secreto para firmar/validar sesiones. Genera uno con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# Duración de la sesión en días
SESSION_TTL_DAYS="30"

# --- Generación de imágenes (Google Gemini) ---------------------------------
# Proveedor: "mock" genera placeholders sin gastar créditos.
#            "gemini" usa la API real (requiere GEMINI_API_KEY).
IMAGE_PROVIDER="mock"
GEMINI_API_KEY=""
# Modelo de generación de imágenes (configurable por si cambia el nombre):
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image-preview"
# Modelo de texto/visión para analizar la imagen de referencia:
GEMINI_TEXT_MODEL="gemini-2.0-flash"

# --- Almacenamiento de imágenes ---------------------------------------------
# "local" guarda en ./storage. "s3" usa un bucket S3/R2 (rellena lo de abajo).
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
# Base pública para servir imágenes locales (en dev sirve /api/files/...)
STORAGE_PUBLIC_BASE_URL="http://localhost:3000/api/files"
# --- S3 / Cloudflare R2 (solo si STORAGE_DRIVER="s3") ---
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# --- Ingesta del Spy --------------------------------------------------------
# Token compartido que la skill de Claude in Chrome envía en el header
# `x-ingest-token` para autenticar el POST /api/ads/ingest y /api/ads/sync.
INGEST_API_TOKEN="cambia-esto-token-de-ingesta"

# --- Fuente de anuncios REALES (Meta Ad Library) ----------------------------
# "mock" devuelve fixtures descargables (no gasta, prueba el flujo completo).
# "apify" usa un actor real de Apify que scrapea el Ad Library público.
# OJO: Apify cobra pay-per-result (cada anuncio devuelto consume créditos).
AD_SOURCE_PROVIDER="mock"
# Token de Apify (https://console.apify.com/account/integrations). Requerido si
# AD_SOURCE_PROVIDER="apify".
APIFY_TOKEN=""
# Actor de Apify. Por defecto el más barato/usado (~USD 0.75/1.000 anuncios):
APIFY_ACTOR_ID="curious_coder~facebook-ads-library-scraper"
# País ISO-2 a vigilar y keywords/nichos (CSV) para la búsqueda automática.
AD_SOURCE_COUNTRY="CO"
# CSV de países para el cron automático (vacío = solo AD_SOURCE_COUNTRY). Ej: "CO,US,MX".
AD_SOURCE_COUNTRIES=""
AD_SOURCE_KEYWORDS=""
# Máximo de anuncios por keyword/corrida (acota el costo pay-per-result).
AD_SOURCE_LIMIT="100"
# Cron (patrón BullMQ, ej. "0 6 * * *" = diario 6am) para ingesta automática.
# Vacío = desactivado (solo ingesta manual vía POST /api/ads/sync).
AD_SOURCE_CRON=""

# --- Worker (proceso BullMQ separado) ---------------------------------------
# Concurrencia de jobs. La de ingesta es más baja para acotar costo de Apify.
WORKER_CONCURRENCY="2"
AD_WORKER_CONCURRENCY="1"

# --- App --------------------------------------------------------------------
NODE_ENV="development"
APP_URL="http://localhost:3000"

# --- Generación de TEXTOS (descripciones, ángulos, copy, titulares) ---------
# "mock" no gasta créditos. "openai" usa la API real. "gemini" reutiliza la key de imágenes.
TEXT_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- MercadoLibre (saturación CO = competencia) -----------------------------
# App gratis en developers.mercadolibre.com. La conexión es por OAuth desde
# Ajustes; el refresh token se guarda CIFRADO en BD (no aquí). Sin credenciales,
# la competencia usa solo la señal de Meta Ad Library CO.
MELI_CLIENT_ID=""
MELI_CLIENT_SECRET=""
# URI de retorno del OAuth. Vacío = se deriva de APP_URL. DEBE coincidir EXACTO
# con la "URI de redirect" registrada en la app de MercadoLibre. En local:
#   http://localhost:3000/api/integrations/meli/callback
MELI_REDIRECT_URI=""
# Sitio de MercadoLibre (MCO = Colombia).
MELI_SITE_ID="MCO"
# Cron (patrón BullMQ) para medir la saturación a diario. Vacío = desactivado.
MELI_SATURATION_CRON="0 8 * * *"

# --- Descubrimiento de productos ganadores (Fase B) ------------------------
# Modo mock: solo la fuente de prueba (sin red ni gasto) para probar el pipeline.
DISCOVERY_MOCK="false"
# Cron del descubrimiento automático (fuentes GRATIS: MercadoLibre). Vacío = off.
DISCOVERY_CRON="0 6 * * *"
# Sitios de MercadoLibre a explorar (CSV). MCO=Colombia, MLM=México, MLA=Argentina…
DISCOVERY_COUNTRIES="MCO"
# Keywords/nichos para descubrir. Vacío = usa AD_SOURCE_KEYWORDS.
DISCOVERY_KEYWORDS=""
# Fuentes opcionales (FASE 2). Google Trends = gratis; Meta/TikTok vía Apify = PAGO
# (off por defecto; reutilizan APIFY_TOKEN cuando se activen).
GOOGLE_TRENDS_ENABLED="false"
META_DISCOVERY="off"
TIKTOK_DISCOVERY="off"
