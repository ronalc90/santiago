// Esquema de datos de WinSpy.
// Capa de acceso a datos: PostgreSQL + Prisma.
// Diseñado para multiusuario desde el día 1 (User.role) aunque hoy lo usen 2 socios.

generator client {
  provider = "prisma-client-js"
  // "native" para dev/Railway; "rhel-openssl-3.0.x" es el runtime de Vercel
  // (Amazon Linux). El CI hace `vercel build` en Debian y sube el prebuilt, así
  // que SIN esto el engine de Prisma no existe en Vercel y toda query falla (500).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// AUTENTICACIÓN Y USUARIOS
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MEMBER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(MEMBER)
  /// Preferencia de apariencia: "light" | "dark" | "reading". Persistente por usuario.
  theme        String    @default("dark")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  products     Product[] @relation("ProductOwner")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// MÓDULO 1 — SPY DE ANUNCIOS
// ---------------------------------------------------------------------------

/// Tienda competidora monitoreada en Meta Ad Library.
model Store {
  id             String   @id @default(cuid())
  name           String
  adLibraryUrl   String?
  country        String   @default("CO")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ads            Ad[]

  @@unique([name, country])
  @@map("stores")
}

/// Clasificación automática del anuncio según el Winner Score y reglas.
enum AdClassification {
  LANZAR // 🔴 alta señal: lanzar ya
  CONSIDERAR // 🟡 buena señal: evaluar
  MONITOREAR // 🟢 señal temprana: vigilar
  SATURADO // ⚪ demasiado tiempo activo / saturado
}

/// Anuncio detectado por el spy. La deduplicación se hace por adId.
model Ad {
  id             String           @id @default(cuid())
  adId           String           @unique // id del anuncio en Meta Ad Library (clave de dedup)
  storeId        String?
  store          Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  storeName      String // copia del nombre por si no hay Store ligada
  country        String           @default("CO")
  adLibraryUrl   String
  copyText       String?
  creativeUrl    String?
  daysActive     Int              @default(0)
  estimatedSpend Float            @default(0)

  // Métrica y clasificación calculadas por la capa de negocio
  winnerScore    Float            @default(0)
  classification AdClassification @default(MONITOREAR)

  // Señales del negocio
  isNew          Boolean          @default(true) // nuevo vs histórico
  sellsInColombia Boolean         @default(false)
  hasUnusedForeignCreative Boolean @default(false)

  detectedAt     DateTime         @default(now())
  firstSeenAt    DateTime         @default(now())
  lastSeenAt     DateTime         @default(now())
  raw            Json? // payload original del spy para auditoría

  productId      String?
  product        Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  snapshots      AdSnapshot[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([storeId])
  @@index([classification])
  @@index([winnerScore])
  @@index([country])
  @@map("ads")
}

/// Foto en el tiempo del estado de un anuncio (una por sincronización). Construye
/// la serie temporal para medir Velocity/momentum (si un anuncio escala o se apaga).
model AdSnapshot {
  id             String           @id @default(cuid())
  adId           String
  ad             Ad               @relation(fields: [adId], references: [id], onDelete: Cascade)
  winnerScore    Float
  daysActive     Int
  estimatedSpend Float            @default(0)
  classification AdClassification
  capturedAt     DateTime         @default(now())

  @@index([adId, capturedAt])
  @@map("ad_snapshots")
}

// ---------------------------------------------------------------------------
// PRODUCTOS Y PIPELINE
// ---------------------------------------------------------------------------

/// Etapas del pipeline del producto.
enum ProductStatus {
  DETECTADO
  VALIDADO
  LANDING_CREADA
  LANZADO
  ESCALANDO
}

/// Disponibilidad logística del producto.
enum DropiAvailability {
  DISPONIBLE
  NO_DISPONIBLE
  A_IMPORTAR
  DESCONOCIDO
}

model Product {
  id                String            @id @default(cuid())
  name              String
  description       String?
  status            ProductStatus     @default(DETECTADO)
  market            String            @default("CO") // país/mercado objetivo
  currency          String            @default("COP")

  sellsInColombia   Boolean           @default(false)
  hasUnusedForeignCreative Boolean    @default(false)
  dropiAvailability DropiAvailability @default(DESCONOCIDO)
  /// Precio de venta de referencia (para el margen). En la moneda del producto.
  salePrice         Int?
  /// Costo por artículo sincronizado desde Shopify (inventoryItem.unitCost). Read-only.
  shopifyUnitCost   Int?
  /// Costo por artículo MANUAL (fallback editable cuando no hay costo en Shopify).
  manualCost        Int?
  /// Costo de envío por unidad (opcional), se resta al margen si existe.
  shippingCost      Int?
  /// Cuándo se actualizó por última vez el costo desde Shopify.
  costUpdatedAt     DateTime?

  /// Nº de publicaciones activas en MercadoLibre CO (saturación). Lo mide el worker.
  saturationCount     Int?
  /// Cuándo cambió por última vez la saturación medida.
  saturationUpdatedAt DateTime?
  /// Keyword editable para medir la saturación; si está vacía, se usa el nombre.
  saturationKeyword   String?

  notes             String?

  ownerId           String?
  owner             User?             @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // --- Motor de Oportunidad (score 0-100 + trazabilidad) ---
  /// Score final 0-100 (re-normalizado a las dimensiones con dato). null = sin evaluar.
  opportunityScore       Float?
  opportunityBand        OpportunityBand?
  /// 0-1: fracción del peso respaldada por fuentes REALES (no estimadas).
  opportunityConfidence  Float?
  opportunityEstimated   Boolean          @default(false)
  demandScore            Int?
  competitionScore       Int?
  marginScore            Int?
  creativesScore         Int?
  /// Trazabilidad completa (pesos, bandas, señales crudas y "por qué" por dimensión).
  opportunityBreakdown   Json?
  opportunityComputedAt  DateTime?

  ads               Ad[]
  landings          LandingProject[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([market])
  @@index([opportunityScore])
  @@index([opportunityBand])
  @@map("products")
}

/// Banda de oportunidad derivada del score (umbrales configurables en Setting).
enum OpportunityBand {
  EXCELENTE
  MUY_BUENO
  BUENO
  RIESGOSO
  RECHAZAR
  SIN_DATOS
}

// ---------------------------------------------------------------------------
// MÓDULO 2 — GENERADOR DE LANDINGS
// ---------------------------------------------------------------------------

enum LandingStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ImageStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Proyecto de landing asociado a un producto. Guarda los inputs y el resultado.
model LandingProject {
  id               String         @id @default(cuid())
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  name             String

  // Inputs del formulario (nombre, precios, público, ángulo, etc.)
  inputs           Json
  // Referencia analizada: 8 elementos extraídos de la imagen de estilo
  styleAnalysis    Json?
  // Foto del producto e imagen de referencia (claves de almacenamiento)
  productPhotoKey  String?
  referenceImageKey String?

  complianceTiktok Boolean        @default(false)
  status           LandingStatus  @default(DRAFT)
  error            String?

  // Producto publicado en Shopify (Admin API): idempotencia y enlace al admin.
  shopifyProductId   String?
  shopifyHandle      String?
  shopifyPublishedAt DateTime?
  // Marca temporal del "claim" de publicación (lock optimista para no duplicar
  // el producto si se pulsa dos veces a la vez). Se limpia al terminar.
  shopifyPublishingAt DateTime?

  images           LandingImage[]
  jobs             Job[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([productId])
  @@index([status])
  @@map("landing_projects")
}

/// Una de las 9 imágenes de la landing.
model LandingImage {
  id          String         @id @default(cuid())
  projectId   String
  project     LandingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slot        Int // 1..9
  type        String // hero, precio, antes_despues, modo_uso, beneficios, ficha, garantia, urgencia, testimonios
  promptEn    String? // prompt en inglés usado para generar
  storageKey  String? // clave del WebP en el almacenamiento
  url         String? // url pública
  width       Int?
  height      Int?
  bytes       Int?
  status      ImageStatus    @default(PENDING)
  error       String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([projectId, slot])
  @@index([projectId])
  @@map("landing_images")
}

// ---------------------------------------------------------------------------
// COLA DE TRABAJOS (registro persistente, espejo de BullMQ)
// ---------------------------------------------------------------------------

enum JobType {
  GENERATE_LANDING
  GENERATE_IMAGE
}

enum JobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
}

model Job {
  id         String         @id @default(cuid())
  type       JobType
  status     JobStatus      @default(PENDING)
  progress   Int            @default(0) // 0..100
  payload    Json?
  result     Json?
  error      String?

  projectId  String?
  project    LandingProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bullJobId  String? // id del job en BullMQ
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([projectId])
  @@map("jobs")
}

// ---------------------------------------------------------------------------
// CONFIGURACIÓN (reglas de negocio editables desde la UI)
// ---------------------------------------------------------------------------

/// Almacén clave-valor para reglas configurables (umbrales del Winner Score, etc.).
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// Tokens OAuth de integraciones externas (MercadoLibre, etc.). access/refresh
/// se guardan CIFRADOS en reposo (AES-256-GCM); nunca en claro ni en logs.
model OAuthToken {
  id           String   @id @default(cuid())
  provider     String   @unique // 'meli'
  accessToken  String // cifrado
  refreshToken String // cifrado
  expiresAt    DateTime
  scope        String?
  externalId   String? // id de usuario en el proveedor (informativo)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("oauth_tokens")
}

// ---------------------------------------------------------------------------
// MÓDULO — DESCUBRIMIENTO DE PRODUCTOS GANADORES (Fase B)
// ---------------------------------------------------------------------------

/// Estado de un candidato en el embudo de descubrimiento.
enum CandidateStatus {
  NUEVO
  REVISADO
  DESCARTADO
  CONVERTIDO
}

/// Producto candidato descubierto por una o varias fuentes (ML, Trends, Meta…).
/// Se deduplica por nombre normalizado y acumula países/fuentes/métricas.
model OpportunityCandidate {
  id             String          @id @default(cuid())
  /// Clave de deduplicación entre fuentes y países.
  normalizedName String          @unique
  name           String
  category       String?
  /// Países donde se detectó (ISO-2/ML site sin prefijo M).
  countries      String[]
  /// Fuentes que lo trajeron (ids de DiscoverySource: 'mercadolibre', 'mock'…).
  sources        String[]

  // Métricas agregadas (la fuente que las tenga las aporta).
  interest       Int? // interés/tendencia (Google Trends), 0-100
  salesCount     Int? // ventas/cantidad vendida si la fuente la expone
  listingsCount  Int? // nº de publicaciones (saturación de la fuente)
  daysActive     Int? // antigüedad de la señal (días)

  // Cruce con Colombia.
  enCO           Boolean           @default(false)
  saturationCO   Int? // nº de publicaciones en MercadoLibre CO

  // Match con Dropi (por CSV; Dropi no da API).
  dropiStatus    DropiAvailability @default(DESCONOCIDO)
  dropiRef       String?

  // Score reutilizando el motor 4×25.
  score4x25      Float?
  scoreBand      OpportunityBand?
  breakdown      Json?

  status         CandidateStatus   @default(NUEVO)
  /// Si se convirtió en producto del pipeline.
  productId      String?

  creatives      OpportunityCreative[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([score4x25])
  @@index([enCO])
  @@map("opportunity_candidates")
}

/// Creativo (imagen/video) de un candidato, re-hospedado en R2 cuando aplica.
model OpportunityCreative {
  id          String               @id @default(cuid())
  candidateId String
  candidate   OpportunityCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  url         String
  type        String // 'image' | 'video'
  country     String?
  source      String
  storageKey  String? // clave en R2 si se descargó
  createdAt   DateTime             @default(now())

  @@index([candidateId])
  @@map("opportunity_creatives")
}

/// Catálogo de Dropi importado por CSV (Dropi no da API): permite matchear
/// candidatos contra lo que SÍ está disponible/importable en Dropi.
model DropiCatalogItem {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  sku            String?
  category       String?
  cost           Int? // costo por artículo (moneda del catálogo)
  stock          Int?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@map("dropi_catalog_items")
}
