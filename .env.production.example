# ==========================================================================
# WinSpy — variables de entorno de PRODUCCIÓN (plantilla)
# NO subir el .env real. Configura estos valores en Vercel y Railway.
#
# Regla de oro del reparto de variables:
#   - Vercel (Web/API): TODO lo de este archivo (la app valida el entorno al
#     arrancar vía lib/config/env.ts).
#   - Railway (Worker): DATABASE_URL, REDIS_URL, AUTH_SECRET, INGEST_API_TOKEN
#     y, además, el bloque de ANUNCIOS REALES (AD_SOURCE_*/APIFY_*), IMAGE_PROVIDER
#     + GEMINI_*, TEXT_PROVIDER + OPENAI_* y STORAGE_DRIVER=s3 + S3_*. El worker es
#     quien llama a getAdSource().fetchAds() y a Gemini, así que esas vars deben
#     estar EN EL WORKER. Sin AUTH_SECRET/INGEST_API_TOKEN el worker NO arranca.
# ==========================================================================

# --- Base de datos (Neon Postgres) -----------------------------------------
# Usa la cadena "pooled" de Neon para la app en Vercel (serverless),
# y añade ?sslmode=require. Para `prisma migrate deploy` usa la NO pooled.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/winspy?sslmode=require"

# --- Redis (Upstash) -------------------------------------------------------
# Usa la URL rediss:// (TLS) que te da Upstash.
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# --- Autenticación ---------------------------------------------------------
# Genera uno nuevo: openssl rand -base64 32  (mínimo 16 caracteres; lo exige env.ts)
# OBLIGATORIO también en el Worker (Railway): si falta, el worker crashea al importar.
AUTH_SECRET="GENERA_UNO_NUEVO_CON_openssl_rand_base64_32"
SESSION_TTL_DAYS="30"

# --- Admin inicial (creación del primer usuario) ---------------------------
# El admin se crea con estas dos variables. NO uses la clave demo.
# Pon una contraseña FUERTE (gestor de contraseñas o `openssl rand -base64 24`).
# Si ADMIN_PASSWORD no se define al crear el admin, se genera una aleatoria fuerte
# y se imprime UNA sola vez por consola: cópiala de inmediato.
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="PON_AQUI_UNA_CLAVE_FUERTE"

# --- Generación de imágenes (Google Gemini) --------------------------------
# Necesario en Vercel y en el Worker (el worker genera las 9 imágenes).
IMAGE_PROVIDER="gemini"
# ⚠️ ROTA la key antes de producción. Genérala en aistudio.google.com/apikey
GEMINI_API_KEY="TU_KEY_DE_PRODUCCION"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GEMINI_TEXT_MODEL="gemini-flash-latest"

# --- Generación de textos (OpenAI / Gemini) --------------------------------
# "mock" no gasta y queda PROHIBIDO en producción (el app lanza al arrancar).
# "openai" exige OPENAI_API_KEY; "gemini" reutiliza GEMINI_API_KEY.
TEXT_PROVIDER="openai"
OPENAI_API_KEY="TU_KEY_DE_OPENAI"
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- Almacenamiento (S3 / Cloudflare R2) -----------------------------------
# Necesario en Vercel y en el Worker (el worker sube las imágenes generadas).
STORAGE_DRIVER="s3"
# Cloudflare R2: el endpoint es https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT="https://ACCOUNTID.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="winspy"
S3_ACCESS_KEY_ID="TU_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="TU_SECRET_KEY"
# URL pública del bucket (R2 public bucket o dominio propio)
S3_PUBLIC_BASE_URL="https://pub-XXXX.r2.dev"

# --- Ingesta del Spy -------------------------------------------------------
# Genera uno nuevo: openssl rand -hex 24  (mínimo 8 caracteres; lo exige env.ts)
# OBLIGATORIO también en el Worker (Railway): si falta, el worker crashea al importar.
INGEST_API_TOKEN="GENERA_UNO_NUEVO_openssl_rand_hex_24"

# --- Fuente de anuncios REALES (Meta Ad Library vía Apify) -----------------
# Estas vars deben estar EN EL WORKER (Railway): el worker es quien llama a
# getAdSource().fetchAds(). En producción, para traer anuncios reales:
#   AD_SOURCE_PROVIDER="apify" + APIFY_TOKEN.
# Si AD_SOURCE_PROVIDER="apify" pero falta APIFY_TOKEN, env.ts lanza.
# Si dejas AD_SOURCE_PROVIDER="mock", la ingesta devuelve datos DEMO (mock).
AD_SOURCE_PROVIDER="apify"
APIFY_TOKEN="TU_TOKEN_DE_APIFY"
APIFY_ACTOR_ID="curious_coder~facebook-ads-library-scraper"
# País ISO-2 a vigilar por defecto.
AD_SOURCE_COUNTRY="CO"
# Lista CSV de keywords/nichos (NO la dejes vacía: sin keywords la ingesta no encola nada).
AD_SOURCE_KEYWORDS="nicho1,nicho2"
# Máximo de resultados por job (controla el costo pay-per-result de Apify).
AD_SOURCE_LIMIT="100"
# Cron (patrón BullMQ) para la ingesta automática; vacío = desactivado.
# Ejemplo: "0 6 * * *" para una corrida diaria a las 06:00.
AD_SOURCE_CRON=""

# --- Concurrencia de los workers BullMQ ------------------------------------
# La de ingesta es más baja a propósito para acotar costo de Apify y carga del CDN.
WORKER_CONCURRENCY="2"
AD_WORKER_CONCURRENCY="1"

# --- Tasa de cambio USD→COP (página de Costos) -----------------------------
# Cámbiala cuando se mueva el tipo de cambio.
USD_COP_RATE="4100"

# --- Publicar landings en Shopify (Admin API) ------------------------------
# OPCIONAL. Sin estas vars el botón "Publicar en Shopify" responde 409 (la
# feature queda desactivada) y el build/boot NO se rompe. Van en Vercel (la
# publicación corre en la ruta web, no en el worker). Crea una "Custom App" en
# Shopify (Configuración → Apps → Desarrollar apps), dale scope write_products y
# copia el Admin API access token (empieza por shpat_).
# Dominio PERMANENTE de la tienda (NO el dominio propio): <tienda>.myshopify.com
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_ADMIN_TOKEN=""          # shpat_...  (secreto; solo en el servidor)
# Versión trimestral de la API (YYYY-MM). Vigila deprecaciones (~12 meses).
SHOPIFY_API_VERSION="2025-10"
# Estado del producto creado: "draft" (recomendado) o "active".
SHOPIFY_PUBLISH_STATUS="draft"

# --- Costos / Margen (leídos de Shopify) -----------------------------------
# Dropi NO da API a terceros: el costo llega a Shopify por la integración oficial
# Dropi→Shopify y WinSpy lo lee con el MISMO token de Shopify (inventoryItem.unitCost).
# REQUIERE que la Custom App de Shopify tenga el scope read_inventory (además de
# write_products). Patrón cron del refresco diario en el worker (vacío = off):
COST_SYNC_CRON="0 7 * * *"

# --- MercadoLibre (saturación CO = competencia) ----------------------------
# OPCIONAL. App gratis en developers.mercadolibre.com. La conexión es por OAuth
# desde Ajustes (botón "Conectar MercadoLibre"); el refresh token se guarda
# CIFRADO en BD (AES-256-GCM con AUTH_SECRET), NO en env. Sin esto, la
# competencia usa solo la señal de Meta Ad Library CO. Van en Vercel (el OAuth
# corre en la ruta web) y en el Worker (que mide la saturación a diario).
MELI_CLIENT_ID=""
MELI_CLIENT_SECRET=""
# DEBE coincidir EXACTO con la "URI de redirect" registrada en la app de ML.
# Vacío = se deriva de APP_URL → https://TU_DOMINIO/api/integrations/meli/callback
MELI_REDIRECT_URI=""
MELI_SITE_ID="MCO"
# Patrón cron del refresco diario de saturación en el worker (vacío = off):
MELI_SATURATION_CRON="0 8 * * *"

# --- App -------------------------------------------------------------------
NODE_ENV="production"
APP_URL="https://santiago.vercel.app"
